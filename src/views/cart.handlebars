<h1>Detalle del Carrito</h1>

{{#if cart.products.length}}
    <ul>
        {{#each cart.products}}
            <li style="margin-bottom: 10px;">
                <strong>Producto:</strong> {{this.product.title}} <br>
                <strong>Precio unitario:</strong> ${{this.product.price}} <br>
                <strong>Cantidad elegida:</strong> {{this.quantity}}
            </li>
        {{/each}}
    </ul>
{{else}}
    <p>Este carrito está vacío.</p>
{{/if}}

<br>
<a href="/">Volver a la lista de productos</a>